{
  "name": "@shopify-dev-toolkit/graphql-queries",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "graphql-codegen --config codegen.ts && tsc",
    "codegen": "graphql-codegen --config codegen.ts",
    "dev": "graphql-codegen --config codegen.ts --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apollo/client": "^3.9.10",
    "graphql": "^16.8.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.2",
    "@graphql-codegen/typescript": "^4.0.6",
    "@graphql-codegen/typescript-operations": "^4.2.0",
    "@shopify-dev-toolkit/eslint-config": "workspace:*",
    "@shopify-dev-toolkit/typescript-config": "workspace:*",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
