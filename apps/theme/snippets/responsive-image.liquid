{% comment %}
  Responsive image snippet with srcset and lazy loading.
  Usage:
    {% render 'responsive-image',
       image: product.featured_image,
       alt: product.title,
       class: 'rounded-lg',
       sizes: '(min-width: 768px) 50vw, 100vw' %}
{% endcomment %}

{% assign image = image | default: false %}
{% assign alt = alt | default: image.alt | default: '' %}
{% assign class = class | default: '' %}
{% assign sizes = sizes | default: '100vw' %}
{% assign loading = loading | default: 'lazy' %}

{% if image %}
  <img
    src="{{ image | image_url: width: 800 }}"
    srcset="
      {{ image | image_url: width: 320 }} 320w,
      {{ image | image_url: width: 640 }} 640w,
      {{ image | image_url: width: 800 }} 800w,
      {{ image | image_url: width: 1200 }} 1200w,
      {{ image | image_url: width: 1600 }} 1600w
    "
    sizes="{{ sizes }}"
    alt="{{ alt | escape }}"
    loading="{{ loading }}"
    decoding="async"
    class="{{ class }}"
    width="{{ image.width }}"
    height="{{ image.height }}"
  >
{% endif %}
